import java.util.Scanner;
public class Main {

            static int[] ProductExceptSelf(int[] arr){
			   int n = arr.length;
               int[] PrefixProduct = new int[n];

         // Finding Prefix Product from left to right including current index. 
         // Started by considering 0th index Prefix Product as arr[0] 
         // because no element was on LHS initially.
			
               PrefixProduct[0] = arr[0];
			   for(int i=1;i<n;i++){
                PrefixProduct[i] = PrefixProduct[i-1]*arr[i];
			   }
        // Tracing back considering (PrefixProduct of previous index * suffix)
        // Updating suffix by multiplying with current index element.

			   int suffix = 1;
			   for(int i=n-1;i>0;i--){
                  PrefixProduct[i] = PrefixProduct[i-1]*suffix;
				  suffix *= arr[i]; 
			   }
			   PrefixProduct[0]=suffix;
			   return PrefixProduct;

			}

	public static void main(String[] args) {
		// write your code here
		Scanner scan = new Scanner(System.in);
		int n = scan.nextInt();

		int[] arr = new int[n];
        for(int i=0;i<n;i++){
			arr[i] = scan.nextInt();
		}

		 int[] ProductArr =  ProductExceptSelf(arr);
         for(int i=0;i<n;i++){
			System.out.print(ProductArr[i]+" ");
		}
	}
}
